# Local development environment template. Copy to .env and fill real values.
# .env is gitignored (NFR2). Never commit real secrets here.

# Port the server binds to. Cloud Run injects this; local fallback is 8080.
PORT=8080

# Neon Postgres DSN. The only T0 secret. Locally read from .env;
# in production injected via Secret Manager. Env var name: NEON_DSN.
NEON_DSN=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Artifact Registry image repo (without tag). Consumed by scripts/build.sh.
IMAGE_REPO=<REGION>-docker.pkg.dev/<PROJECT_ID>/<AR_REPO>/<IMAGE>

# Feature flag for the T5 observability event-ingestion endpoint (POST /v1/events).
# Defaults to OFF: the endpoint is NOT mounted unless this is exactly "true", so it
# is not exposed to the public until the client integrates (D2, seam-first). Leave
# unset/commented to keep the route returning 404. Any value other than "true"
# (including empty) keeps it disabled.
# EVENTS_INGEST_ENABLED=true
