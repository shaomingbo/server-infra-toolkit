# Local development environment template. Copy to .env and fill real values.
# .env is gitignored (NFR2). Never commit real secrets here.

# Port the server binds to. Cloud Run injects this; local fallback is 8080.
PORT=8080

# Neon Postgres DSN. The only T0 secret. Locally read from .env;
# in production injected via Secret Manager. Env var name: NEON_DSN.
NEON_DSN=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Artifact Registry image repo (without tag). Consumed by scripts/build.sh.
IMAGE_REPO=<REGION>-docker.pkg.dev/<PROJECT_ID>/<AR_REPO>/<IMAGE>

# Optional: override the runtime service account that scripts/deploy-precheck.sh
# checks. Left unset, the script derives the default compute SA from the project
# number (<PROJECT_NUMBER>-compute@developer.gserviceaccount.com). Set this only if
# the service runs under a custom (non-default) SA.
# RUNTIME_SERVICE_ACCOUNT=<SA_NAME>@<PROJECT_ID>.iam.gserviceaccount.com

# Feature flag for the T5 observability event-ingestion endpoint (POST /v1/events).
# Defaults to OFF: the endpoint is NOT mounted unless this is exactly "true", so it
# is not exposed to the public until the client integrates (D2, seam-first). Leave
# unset/commented to keep the route returning 404. Any value other than "true"
# (including empty) keeps it disabled.
#
# BEFORE flipping this to true you MUST also set EVENTS_INGEST_TOKEN_SHA256S below:
# the server fails closed (refuses to start) if the endpoint is enabled with no
# accepted hash, so you cannot accidentally open an unauthenticated write path.
# EVENTS_INGEST_ENABLED=true

# Accepted ingest-token SHA-256 hashes for POST /v1/events auth (1-2 entries,
# comma-separated, each a lowercase 64-char hex digest: ^[0-9a-f]{64}$). This env
# stores ONLY hashes, never the plaintext token. Two entries (current,previous)
# support a rolling token rotation. Compute a hash from the real token with
# `printf '%s' "$TOKEN" | shasum -a 256` (ensure $TOKEN is non-empty — the hash of
# empty input is rejected as a likely "unset variable" mistake). Required whenever
# EVENTS_INGEST_ENABLED=true. The value below is a placeholder, NOT a real hash.
# EVENTS_INGEST_TOKEN_SHA256S=<64-hex-sha256-of-current-token>[,<64-hex-sha256-of-previous-token>]

# ---------------------------------------------------------------------------
# Offline-package v2 signing subcommand (`go run ./cmd/api -sign-active`, T4).
# Used ONLY by the one-shot offline signer; the running HTTP server never reads
# these. The private key is the only secret here; the rest are public identifiers.
# ---------------------------------------------------------------------------

# Ed25519 signing private key, standard padded base64 of EITHER a 32-byte seed OR
# a 64-byte full key. Wrapped in config.Secret so it never logs or serializes in
# plaintext. The value below is a placeholder, NOT a real key.
# OFFLINE_SIGN_PRIVATE_KEY=<base64-ed25519-seed-or-full-key>

# The keyId to sign under (case-sensitive, untrimmed). Must match a keyId the app
# has published a public key for.
# OFFLINE_SIGN_KEY_ID=<key-id>

# Comma-separated list of keyIds whose local status is Active (allowed to sign).
# A keyId absent from this list is treated as Minted and refused fail-closed.
#
# PUBLISH-ORDER PRECONDITION (D9, availability-critical): add a keyId here ONLY
# after the app has FULLY rolled out that keyId's public key to both client ends.
# Signing with a keyId the app does not yet know causes the app to fail closed
# (unknownKeyId) — flipping a key Active too early is an availability incident,
# not a recoverable warning. Promoting a key to Active is a deliberate human step.
# OFFLINE_SIGN_ACTIVE_KEY_IDS=<key-id>[,<other-active-key-id>]

# The public key the app has PUBLISHED for OFFLINE_SIGN_KEY_ID: standard padded
# base64 of the RAW 32-byte Ed25519 key (the same wire form the app ships), copied
# from the app's release record. NOT a secret. The signer checks the private key
# above derives exactly this published key (FR9); a mismatch means the wrong
# private key was paired with this keyId and signing is refused fail-closed. The
# value below is a placeholder, NOT a real key.
# OFFLINE_SIGN_EXPECTED_PUBLIC_KEY=<base64-raw-32-byte-ed25519-public-key>
