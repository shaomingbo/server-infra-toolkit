{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shaomingbo/server-infra-toolkit/internal/modules/auth/contract/login.schema.json",
  "title": "LoginSession",
  "description": "Wire shape of the POST /v1/auth/login success response (T2 frozen client contract). expiresAt is the access token's expiry as a Unix MILLISECOND absolute timestamp (integer), NOT seconds.",
  "type": "object",
  "additionalProperties": false,
  "required": ["userId", "accessToken", "refreshToken", "expiresAt"],
  "properties": {
    "userId": {
      "type": "string"
    },
    "accessToken": {
      "type": "string"
    },
    "refreshToken": {
      "type": "string"
    },
    "expiresAt": {
      "type": "integer"
    }
  }
}
